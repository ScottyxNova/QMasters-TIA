        font-size: 1.2rem;
        word-break: break-all;
        color: #fff;
        display: block;
        margin-top: 10px;
    }
    
    /* Table styling: Black text on white background */
    .ioc-table {
        background-color: #fff !important;
        color: #000 !important;
        table-layout: fixed; /* Force fixed layout to control widths */
        width: 100%;
    }
    .ioc-table thead th {
        background-color: #f0f0f0 !important;
        color: #000 !important;
        border-bottom: 2px solid #ccc !important;
        white-space: nowrap;
    }
    .ioc-table tbody td {
        color: #000 !important;
        vertical-align: middle;
        padding: 8px 4px !important;
    }
    .ioc-table code {
        color: #000 !important;
        background: transparent;
        padding: 0;
        font-family: 'Fira Code', monospace;
        font-size: 0.9rem;
        word-break: break-all; /* Ensure wrapping */
        display: block;
        line-height: 1.2;
    }
    
    /* Column Width Optimization */
    .col-type { width: 80px; }
    .col-
 
 
 cat egory { width: 150px; }
    .col-value { width: auto; }
    .col-info { width: 200px; }

    /* Highlight searched row in yellow */
    .highlight-row {
        background-color: #ffff00 !important; /* Yellow highlight */
    }
    .highlight-row td, .highlight-row code {
        font-weight: bold !important;
    }

    /* Filter inputs styling */
    .filter-input {
        background-color: #fff !important;
        border: 1px solid #ccc !important;
        color: #000 !important;
        font-size: 0.75rem;
        padding: 2px 4px;
        width: 100%;
    }

    /* Download Button Styling */
    .btn-download {
        border: 1px solid var(--neon-green);
        color: var(--neon-green);
        background: transparent;
        font-size: 0.8rem;
        padding: 5px 15px;
        transition: all 0.3s;
    }
    .btn-download:hover {
        background: var(--neon-green);
        color: #000;
        box-shadow: 0 0 10px var(--neon-green);
    }
</style>

<div class="row mb-4">
    <div class="col">
        <div class="card">
            <div class="card-body d-flex justify-content-between align-items-start">
                <div>
<div class="mb-3"><img src="https://raw.githubusercontent.com/ScottyxNova/QMasters-TIA/refs/heads/main/LOGO.png" style="max-width:140px;"></div>
                    <h3 class="card-title mb-0" style="color: var(--neon-green) !important;">SEARCH_RESULTS:</h3>
                    <span class="top-query-text">{{ query }}</span>
                </div>
                <a href="{{ url_for('index') }}" class="btn btn-outline-secondary btn-sm">NEW_QUERY</a>
            </div>
        </div>
    </div>
</div>

{% if results and results|length > 0 %}
    {% for event_data in results %}
        {% if event_data.Event %}
            {% set event = event_data.Event %}
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0" style="color: var(--neon-green) !important;">{{ event.info }}</h5>
                    <span class="badge bg-primary">THREAT_LVL: {{ event.threat_level_id }}</span>
                </div>
                <div class="card-body">
                    <div class="row mb-4" style="font-size: 0.85rem; color: #888;">
                        {% if event.date %}<div class="col-md-3">DATE: <span style="color: #fff;">{{ event.date }}</span></div>{% endif %}
                        {% if event.Org and event.Org.name %}<div class="col-md-3">ORG: <span style="color: #fff;">{{ event.Org.name }}</span></div>{% endif %}
                        {% if event.Orgc and event.Orgc.name %}<div class="col-md-3">ORGC: <span style="color: #fff;">{{ event.Orgc.name }}</span></div>{% endif %}
                        {% if event.attribute_count %}<div class="col-md-3">ATTR_COUNT: <span style="color: #fff;">{{ event.attribute_count }}</span></div>{% endif %}
                    </div>

                    {% if event.Tag %}
                    <div class="mb-4">
                        <span style="color: #888; font-size: 0.85rem;">TAGS:</span>
                        {% for tag in event.Tag %}
                            <span class="badge tag-badge" style="background-color: {{ tag.colour }}; color: #000; border: 1px solid #000; font-size: 0.7rem; margin-right: 5px;">{{ tag.name }}</span>
                        {% endfor %}
                    </div>
                    {% endif %}

                    {% if event.Attribute %}
                    <div class="d-flex justify-content-between align-items-center mt-4 mb-3" style="border-bottom: 1px solid #333; padding-bottom: 5px;">
                        <h6 class="mb-0" style="color: var(--neon-green);">IOC Reference \\ Related List</h6>
                        <button class="btn btn-download" onclick="downloadCSV('table-{{ event.id }}', 'event_{{ event.id }}_iocs.csv')">DOWNLOAD_CSV</button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover ioc-table" id="table-{{ event.id }}">
                            <thead>
                                <tr>
                                    <th class="col-type">TYPE</th>
                                    <th class="col-
 
 
 cat egory">
 
 
 cat EGORY</th>
                                    <th class="col-value">VALUE</th>
                                    <th class="col-info">INFO</th>
                                </tr>
                                <tr class="filter-row">
                                    <th><input type="text" class="filter-input" onkeyup="filterTable('table-{{ event.id }}', 0)" placeholder="Type..."></th>
                                    <th><input type="text" class="filter-input" onkeyup="filterTable('table-{{ event.id }}', 1)" placeholder="
 
 
 cat egory..."></th>
                                    <th><input type="text" class="filter-input" onkeyup="filterTable('table-{{ event.id }}', 2)" placeholder="Value..."></th>
                                    <th><input type="text" class="filter-input" onkeyup="filterTable('table-{{ event.id }}', 3)" placeholder="Info..."></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for attr in event.Attribute %}
                                <tr class="{% if attr.value == query %}highlight-row{% endif %}">
                                    <td class="col-type"><span class="badge bg-dark border border-secondary text-secondary" style="font-size: 0.7rem;">{{ attr.type }}</span></td>
                                    <td class="col-
 
 
 cat egory" style="font-size: 0.8rem;">{{ attr.
 
 
 cat egory }}</td>
                                    <td class="col-value"><code>{{ attr.value }}</code></td>
                                    <td class="col-info" style="font-size: 0.8rem;">{{ event.info or '-' }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    {% endfor %}
{% else %}
    <div class="alert alert-info">
        <h4 class="alert-heading" style="color: var(--neon-green) !important;">NO_RESULTS_FOUND</h4>
        <p>The IOC value you searched for was not found in the database or the API returned an empty response.</p>
    </div>
{% endif %}

<div class="card mt-5" style="border-color: #333;">
    <div class="card-header bg-dark" style="border-bottom-color: #333;">
        <h6 class="mb-0" style="color: #666;">RAW_JSON_DATA_STREAM</h6>
    </div>
    <div class="card-body p-0">
        <pre class="m-0 p-3" style="max-height: 400px; overflow-y: auto; font-size: 0.8rem;"><code>{{ raw_data | tojson(indent=2) }}</code></pre>
    </div>
</div>

<script>
function filterTable(tableId, colIndex) {
    var input, filter, table, tr, td, i, txtValue;
    table = document.getElementById(tableId);
    var inputs = table.getElementsByClassName('filter-input');
    
    tr = table.getElementsByTagName("tr");

    // Loop through all table rows, starting from index 2 (after headers and filter row)
    for (i = 2; i < tr.length; i++) {
        var showRow = true;
        
        // Check all filters
        for (var j = 0; j < inputs.length; j++) {
            filter = inputs[j].value.toUpperCase();
            if (filter !== "") {
                td = tr[i].getElementsByTagName("td")[j];
                if (td) {
                    txtValue = td.textContent || td.innerText;
                    if (txtValue.toUpperCase().indexOf(filter) === -1) {
                        showRow = false;
                        break;
                    }
                }
            }
        }
        
        if (showRow) {
            tr[i].style.display = "";
        } else {
            tr[i].style.display = "none";
        }
    }
}

function downloadCSV(tableId, filename) {
    var csv = [];
    var table = document.getElementById(tableId);
    var rows = table.querySelectorAll("tr");
    
    // Get headers (first row only)
    var headerRow = rows[0];
    var headerCols = headerRow.querySelectorAll("th");
    var headerData = [];
    for (var j = 0; j < headerCols.length; j++) {
        headerData.push('"' + headerCols[j].innerText.replace(/"/g, '""') + '"');
    }
    csv.push(headerData.join(","));

    // Get data rows (skip the filter row at index 1)
    for (var i = 2; i < rows.length; i++) {
        // Only export visible rows (respecting current filters)
        if (rows[i].style.display !== "none") {
            var row = [], cols = rows[i].querySelectorAll("td");
            for (var j = 0; j < cols.length; j++) {
                row.push('"' + cols[j].innerText.replace(/"/g, '""') + '"');
            }
            csv.push(row.join(","));
        }
    }

    // Download CSV file
    var csvFile = new Blob([csv.join("\n")], {type: "text/csv"});
    var downloadLink = document.createElement("a");
    downloadLink.download = filename;
    downloadLink.href = window.URL.createObjectURL(csvFile);
    downloadLink.style.display = "none";
    document.body.appendChild(downloadLink);
    downloadLink.click();
    document.body.removeChild(downloadLink);
}
</script>
{% endblock %}
